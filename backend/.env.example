# OneSignal Identity Verification – copy this file to .env and fill in real values.
# Never commit .env (it contains the private key).

# Your OneSignal App ID (from Dashboard > Settings > Keys & IDs)
ONESIGNAL_APP_ID=your-app-id-here

# Private key PEM from OneSignal Dashboard > Settings > Keys & IDs > Identity Verification.
# Paste the full PEM including -----BEGIN EC PRIVATE KEY----- and -----END EC PRIVATE KEY-----.
# Use quotes and keep line breaks as \n if needed, or put the whole key on one line.
ONESIGNAL_IDENTITY_VERIFICATION_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_CONTENT_HERE\n-----END EC PRIVATE KEY-----"
